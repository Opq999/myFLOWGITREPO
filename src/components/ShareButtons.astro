---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;

const whatsapp = `https://wa.me/?text=${encodeURIComponent(`${title} — ${url}`)}`;
const x = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
---

<div class="flex flex-wrap items-center gap-2">
  <span class="text-sm font-semibold text-zinc-700">Share:</span>
  <a
    href={whatsapp}
    target="_blank"
    rel="noopener"
    class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-bold text-white hover:bg-brand-700"
  >
    WhatsApp
  </a>
  <a
    href={x}
    target="_blank"
    rel="noopener"
    class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-bold text-white hover:bg-zinc-700"
  >
    X
  </a>
  <button
    type="button"
    class="copy-link-btn rounded-lg border border-zinc-300 px-4 py-2 text-sm font-bold text-zinc-700 hover:border-brand-600"
    data-url={url}
  >
    Copy link
  </button>
</div>

<script is:inline>
  document.querySelectorAll('.copy-link-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(btn.dataset.url).then(function () {
        var original = btn.textContent;
        btn.textContent = 'Copied ✓';
        setTimeout(function () {
          btn.textContent = original;
        }, 2000);
      });
    });
  });
</script>
