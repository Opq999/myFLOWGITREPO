---
import { SITE } from '../site.config';
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/80 backdrop-blur-md">
  <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center gap-x-5 gap-y-2 px-4 py-3 sm:px-6">
    <a href="/" class="font-display text-2xl font-semibold tracking-[-0.02em] text-ink-900">
      {SITE.name}<span class="text-accent">.</span>
    </a>
    <nav
      class="order-3 flex w-full gap-5 font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-500 sm:order-2 sm:w-auto"
    >
      <a href="/workflows/" class="py-1 transition-colors hover:text-accent">Workflows</a>
      <a href="/about/" class="py-1 transition-colors hover:text-accent">About</a>
      <a href="/submit/" class="py-1 transition-colors hover:text-accent">Submit</a>
    </nav>
    <button
      id="search-toggle"
      type="button"
      class="order-2 ml-auto rounded-lg border border-line-strong bg-surface px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.15em] text-ink-600 transition-colors hover:border-accent hover:text-accent sm:order-3"
      aria-expanded="false"
      aria-controls="search-panel"
    >
      ⌕ Search
    </button>
  </div>
  <div id="search-panel" hidden class="border-t border-line bg-surface/95">
    <div class="mx-auto w-full max-w-6xl px-4 py-4 sm:px-6">
      <div id="search"></div>
      <noscript><p class="text-sm text-ink-400">Search needs JavaScript enabled.</p></noscript>
    </div>
  </div>
</header>

<!-- Pagefind UI is loaded lazily on first open: zero search JS on page load. -->
<script is:inline>
  (function () {
    var loaded = false;
    var btn = document.getElementById('search-toggle');
    var panel = document.getElementById('search-panel');
    if (!btn || !panel) return;
    btn.addEventListener('click', function () {
      panel.hidden = !panel.hidden;
      btn.setAttribute('aria-expanded', String(!panel.hidden));
      if (loaded || panel.hidden) return;
      loaded = true;
      var css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(css);
      var s = document.createElement('script');
      s.src = '/pagefind/pagefind-ui.js';
      s.onload = function () {
        /* global PagefindUI */
        new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
        var input = panel.querySelector('input');
        if (input) input.focus();
      };
      document.body.appendChild(s);
    });
  })();
</script>
