---
import { SITE } from '../site.config';
---

{
  SITE.buttondownUsername && (
    <section class="relative overflow-hidden rounded-2xl border border-ink-800 bg-ink-900 p-6">
      <div class="glow h-40 w-40 bg-volt-400/20" style="top:-3rem; right:-3rem;" aria-hidden="true" />
      <p class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-volt-300">Newsletter</p>
      <h2 class="mt-1 font-display text-xl font-bold text-white">Get new workflows weekly</h2>
      <p class="mt-1 text-sm text-zinc-400">One email a week. Free workflows only. Unsubscribe anytime.</p>
      <form
        action={`https://buttondown.com/api/emails/embed-subscribe/${SITE.buttondownUsername}`}
        method="post"
        target="_blank"
        class="mt-4 flex flex-wrap gap-2"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="min-w-0 flex-1 rounded-lg border border-ink-700 bg-ink-950 px-3 py-2.5 text-sm text-zinc-200 placeholder:text-zinc-600 focus:border-volt-400 focus:outline-none"
        />
        <button
          type="submit"
          class="rounded-lg bg-volt-400 px-5 py-2.5 font-display text-sm font-bold text-ink-950 hover:bg-volt-300"
        >
          Subscribe
        </button>
      </form>
    </section>
  )
}
