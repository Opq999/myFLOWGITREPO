---
interface Props {
  badge: 'sourced' | 'tested' | 'community-verified';
}
const { badge } = Astro.props;

const styles: Record<Props['badge'], string> = {
  sourced: 'border-line-strong bg-paper-2 text-ink-600',
  tested: 'border-volt-400/50 bg-volt-400/10 text-volt-500',
  'community-verified': 'border-blue-500/40 bg-blue-500/10 text-blue-700',
};
const labels: Record<Props['badge'], string> = {
  sourced: 'Sourced',
  tested: 'Tested ✓',
  'community-verified': 'Verified',
};
---

<span
  class={`inline-block rounded-full border px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.12em] ${styles[badge]}`}
>
  {labels[badge]}
</span>
