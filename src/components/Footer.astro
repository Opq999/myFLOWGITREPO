---
import { SITE } from '../site.config';
import NewsletterForm from './NewsletterForm.astro';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-line bg-paper-2/50">
  <div class="ticker border-b border-line py-2.5" aria-hidden="true">
    <div class="ticker__track font-mono text-[10px] font-semibold uppercase tracking-[0.25em] text-ink-400">
      {
        Array.from({ length: 2 }).map(() => (
          <span>
            Exact steps · Exact prompts · Real sources · Free tools first · Built for 🇳🇬, open to
            the world · New workflows daily ·&nbsp;
          </span>
        ))
      }
    </div>
  </div>
  {/* Second newsletter capture point (site-wide). Renders nothing until Buttondown is configured. */}
  {
    SITE.buttondownUsername && (
      <div class="mx-auto w-full max-w-6xl border-b border-line px-4 py-8 sm:px-6">
        <NewsletterForm compact />
      </div>
    )
  }
  <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-8 sm:px-6">
    <div>
      <p class="font-display text-xl font-semibold text-ink-900">
        {SITE.name}<span class="text-accent">.</span>
      </p>
      <p class="mt-1 text-sm text-ink-500">© {year} · Reproducible AI workflows, refreshed daily.</p>
    </div>
    <nav class="flex gap-5 font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-500">
      <a href="/about/" class="py-2 hover:text-accent">About</a>
      <a href="/submit/" class="py-2 hover:text-accent">Submit</a>
      <a href="/services/" class="py-2 hover:text-accent">Work with me</a>
    </nav>
  </div>
</footer>
