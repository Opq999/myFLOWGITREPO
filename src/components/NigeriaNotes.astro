---
interface Props {
  notes: string;
}
const { notes } = Astro.props;
---

<aside class="rounded-xl border border-volt-400/30 bg-volt-400/[0.06] p-4">
  <p class="mb-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-volt-300">
    🇳🇬 Nigeria notes — data &amp; free-tier check
  </p>
  <p class="text-sm leading-relaxed text-zinc-200">{notes}</p>
</aside>
