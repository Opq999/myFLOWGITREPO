---
import type { Tool } from '../lib/workflow-schema';

interface Props {
  tools: Tool[];
}
const { tools } = Astro.props;

const pricingStyles: Record<Tool['pricing'], string> = {
  free: 'bg-brand-100 text-brand-800',
  freemium: 'bg-amber-100 text-amber-800',
  paid: 'bg-red-100 text-red-800',
};
---

<ul class="flex flex-wrap gap-2">
  {
    tools.map((tool) => {
      const href = tool.affiliateUrl || tool.url;
      const rel = tool.affiliateUrl ? 'nofollow sponsored noopener' : 'noopener';
      return (
        <li>
          <a
            href={href}
            rel={rel}
            target="_blank"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-200 px-3 py-1.5 text-sm font-medium hover:border-brand-600"
          >
            {tool.name}
            <span class={`rounded-full px-2 py-0.5 text-[11px] font-semibold ${pricingStyles[tool.pricing]}`}>
              {tool.pricing}
            </span>
          </a>
        </li>
      );
    })
  }
</ul>
