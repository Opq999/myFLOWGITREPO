---
import type { Tool } from '../lib/workflow-schema';

interface Props {
  tools: Tool[];
}
const { tools } = Astro.props;

const pricingStyles: Record<Tool['pricing'], string> = {
  free: 'border-volt-400/40 bg-volt-400/10 text-volt-300',
  freemium: 'border-amber-400/40 bg-amber-400/10 text-amber-300',
  paid: 'border-red-400/40 bg-red-400/10 text-red-300',
};
---

<ul class="flex flex-wrap gap-2">
  {
    tools.map((tool) => {
      const href = tool.affiliateUrl || tool.url;
      const rel = tool.affiliateUrl ? 'nofollow sponsored noopener' : 'noopener';
      return (
        <li>
          <a
            href={href}
            rel={rel}
            target="_blank"
            class="inline-flex items-center gap-2 rounded-lg border border-ink-700 bg-ink-900 px-3 py-1.5 text-sm font-semibold text-zinc-200 transition-colors hover:border-volt-400"
          >
            {tool.name}
            <span
              class={`rounded-full border px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wide ${pricingStyles[tool.pricing]}`}
            >
              {tool.pricing}
            </span>
          </a>
        </li>
      );
    })
  }
</ul>
