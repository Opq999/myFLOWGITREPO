---
import type { Tool } from '../lib/workflow-schema';

interface Props {
  tools: Tool[];
}
const { tools } = Astro.props;

const pricingStyles: Record<Tool['pricing'], string> = {
  free: 'border-cat-jobs/40 bg-cat-jobs/10 text-cat-jobs',
  freemium: 'border-cat-freelance/40 bg-cat-freelance/10 text-cat-freelance',
  paid: 'border-red-500/40 bg-red-500/10 text-red-600',
};
---

<ul class="flex flex-wrap gap-2">
  {
    tools.map((tool) => {
      const href = tool.affiliateUrl || tool.url;
      const rel = tool.affiliateUrl ? 'nofollow sponsored noopener' : 'noopener';
      return (
        <li>
          <a
            href={href}
            rel={rel}
            target="_blank"
            class="inline-flex items-center gap-2 rounded-lg border border-line-strong bg-surface px-3 py-1.5 text-sm font-semibold text-ink-800 transition-colors hover:border-accent"
          >
            {tool.name}
            <span
              class={`rounded-full border px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wide ${pricingStyles[tool.pricing]}`}
            >
              {tool.pricing}
            </span>
          </a>
        </li>
      );
    })
  }
</ul>
