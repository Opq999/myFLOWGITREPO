---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="That page doesn't exist.">
  <div class="relative overflow-hidden py-20 text-center">
    <div class="glow h-56 w-56 bg-volt-400/15" style="top:0; left:50%; transform:translateX(-50%);" aria-hidden="true"></div>
    <p class="font-display text-8xl font-semibold text-outline">404</p>
    <h1 class="mt-4 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900">This page doesn't exist</h1>
    <p class="mt-2 text-ink-500">, but the workflows do.</p>
    <a
      href="/workflows/"
      class="mt-7 inline-block rounded-full bg-ink-900 px-6 py-3 font-sans font-semibold text-paper transition-transform hover:scale-[1.03]"
    >
      Browse the library →
    </a>
  </div>
</Base>
