---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="That page doesn't exist.">
  <div class="py-16 text-center">
    <p class="text-5xl">🧭</p>
    <h1 class="mt-4 text-2xl font-extrabold">Page not found</h1>
    <p class="mt-2 text-zinc-600">That page doesn't exist — but the workflows do.</p>
    <a
      href="/workflows/"
      class="mt-5 inline-block rounded-lg bg-brand-600 px-5 py-2.5 font-bold text-white hover:bg-brand-700"
    >
      Browse all workflows
    </a>
  </div>
</Base>
