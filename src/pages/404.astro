---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="That page doesn't exist.">
  <div class="relative overflow-hidden py-20 text-center">
    <div class="glow h-56 w-56 bg-volt-400/10" style="top:0; left:50%; transform:translateX(-50%);" aria-hidden="true"></div>
    <p class="font-display text-7xl font-bold text-outline">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold text-white">This page doesn't exist</h1>
    <p class="mt-2 text-zinc-400">— but the workflows do.</p>
    <a
      href="/workflows/"
      class="mt-7 inline-block rounded-xl bg-volt-400 px-6 py-3 font-display font-bold text-ink-950 transition-transform hover:scale-[1.03] hover:bg-volt-300"
    >
      Browse the library →
    </a>
  </div>
</Base>
