---
import Base from '../layouts/Base.astro';
import { SITE } from '../site.config';
---

<Base title="Submit a workflow" description="Share an AI workflow that worked for you — we'll review it and publish it with credit.">
  <p class="font-mono text-[11px] font-bold uppercase tracking-[0.3em] text-accent">Contribute</p>
  <h1 class="mt-2 font-display text-4xl font-medium tracking-[-0.02em] text-ink-900 sm:text-5xl">Submit a workflow</h1>
  <p class="mt-3 max-w-xl leading-relaxed text-ink-600">
    Used AI to get something real done? Share the steps and prompts — we'll review it, and if it's
    reproducible we'll publish it with full credit to you.
  </p>

  {
    SITE.tallyFormId ? (
      <iframe
        src={`https://tally.so/embed/${SITE.tallyFormId}?alignLeft=1&hideTitle=1&transparentBackground=1`}
        loading="lazy"
        width="100%"
        height="600"
        style="border:0"
        title="Submit a workflow"
        class="mt-6"
      />
    ) : (
      <div class="mt-6 rounded-2xl border border-line bg-surface p-6 shadow-[0_1px_2px_rgba(28,23,19,0.04)]">
        <p class="font-display text-lg font-semibold text-ink-900">Submissions are opening soon.</p>
        <p class="mt-1 text-sm text-ink-500">
          In the meantime, email your workflow (steps + prompts + a link to where you shared it) to{' '}
          <a href="mailto:opeyemiolowosoke@gmail.com" class="text-accent underline underline-offset-2">
            opeyemiolowosoke@gmail.com
          </a>
          .
        </p>
      </div>
    )
  }
</Base>
