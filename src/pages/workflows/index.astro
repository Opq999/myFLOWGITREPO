---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkflowCard from '../../components/WorkflowCard.astro';
import PersonaFilter from '../../components/PersonaFilter.astro';
import { CATEGORY_META } from '../../lib/categories';
import { CATEGORIES, BADGES, DIFFICULTIES } from '../../lib/workflow-schema';

const workflows = (await getCollection('workflows', (e) => e.data.published)).sort(
  (a, b) => b.data.ingestedAt.valueOf() - a.data.ingestedAt.valueOf()
);
---

<Base title="All workflows" description="Browse every AI workflow: filter by category, difficulty, badge, or free tools only.">
  <p class="font-mono text-[11px] font-bold uppercase tracking-[0.3em] text-accent">The library</p>
  <h1 class="mt-2 font-display text-4xl font-medium tracking-[-0.02em] text-ink-900 sm:text-5xl">All workflows</h1>
  <p class="mt-2 text-ink-500">{workflows.length} reproducible AI workflows, newest first.</p>

  <form class="mt-6 flex flex-wrap items-center gap-2" id="filters">
    <select
      data-filter="category"
      class="rounded-full border border-line-strong bg-surface px-4 py-2.5 text-sm font-semibold text-ink-800 focus:border-accent"
      aria-label="Category"
    >
      <option value="">All categories</option>
      {CATEGORIES.map((c) => <option value={c}>{CATEGORY_META[c].label}</option>)}
    </select>
    <select
      data-filter="difficulty"
      class="rounded-full border border-line-strong bg-surface px-4 py-2.5 text-sm font-semibold text-ink-800 focus:border-accent"
      aria-label="Difficulty"
    >
      <option value="">Any difficulty</option>
      {DIFFICULTIES.map((d) => <option value={d}>{d}</option>)}
    </select>
    <select
      data-filter="badge"
      class="rounded-full border border-line-strong bg-surface px-4 py-2.5 text-sm font-semibold text-ink-800 focus:border-accent"
      aria-label="Badge"
    >
      <option value="">Any badge</option>
      {BADGES.map((b) => <option value={b}>{b}</option>)}
    </select>
    <label
      class="flex cursor-pointer items-center gap-2 rounded-full border border-line-strong bg-surface px-4 py-2.5 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-ink-700 transition-colors has-checked:border-accent has-checked:text-accent"
    >
      <input type="checkbox" id="free-only" class="accent-[#ff4d2e]" />
      Free tools only
    </label>
  </form>

  <PersonaFilter />

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="workflow-list">
    {workflows.map((w) => <WorkflowCard workflow={w} />)}
  </div>
  <p id="no-results" hidden class="mt-10 text-center text-ink-400">
    No workflows match these filters yet. The library grows daily, check back tomorrow.
  </p>
</Base>

<!-- Client-side filtering on data attributes; state synced to URL params. -->
<script is:inline>
  (function () {
    var selects = Array.prototype.slice.call(document.querySelectorAll('#filters [data-filter]'));
    var freeToggle = document.getElementById('free-only');
    var personaChips = Array.prototype.slice.call(document.querySelectorAll('.persona-chip'));
    var cards = Array.prototype.slice.call(document.querySelectorAll('.workflow-card'));
    var noResults = document.getElementById('no-results');
    var activePersona = '';

    function setPersona(persona) {
      activePersona = persona;
      personaChips.forEach(function (c) {
        c.setAttribute('aria-pressed', c.dataset.persona === persona ? 'true' : 'false');
      });
    }

    function apply() {
      var active = {};
      selects.forEach(function (s) {
        active[s.dataset.filter] = s.value;
      });
      var freeOnly = freeToggle.checked;
      var visible = 0;
      cards.forEach(function (card) {
        var personas = (card.dataset.personas || '').split(' ');
        var show =
          (!active.category || card.dataset.category === active.category) &&
          (!active.difficulty || card.dataset.difficulty === active.difficulty) &&
          (!active.badge || card.dataset.badge === active.badge) &&
          (!freeOnly || card.dataset.free === '1') &&
          (!activePersona || personas.indexOf(activePersona) !== -1);
        card.hidden = !show;
        if (show) visible++;
      });
      noResults.hidden = visible > 0;

      var params = new URLSearchParams();
      Object.keys(active).forEach(function (k) {
        if (active[k]) params.set(k, active[k]);
      });
      if (freeOnly) params.set('free', '1');
      if (activePersona) params.set('persona', activePersona);
      var qs = params.toString();
      history.replaceState(null, '', qs ? '?' + qs : location.pathname);
    }

    var params = new URLSearchParams(location.search);
    selects.forEach(function (s) {
      var v = params.get(s.dataset.filter);
      if (v) s.value = v;
      s.addEventListener('change', apply);
    });
    if (params.get('free') === '1') freeToggle.checked = true;
    freeToggle.addEventListener('change', apply);

    personaChips.forEach(function (c) {
      c.addEventListener('click', function () {
        setPersona(c.dataset.persona);
        apply();
      });
    });
    var initialPersona = params.get('persona') || '';
    var hasChip = personaChips.some(function (c) {
      return c.dataset.persona === initialPersona;
    });
    setPersona(hasChip ? initialPersona : '');

    apply();
  })();
</script>
