---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Badge from '../../components/Badge.astro';
import ToolsList from '../../components/ToolsList.astro';
import NigeriaNotes from '../../components/NigeriaNotes.astro';
import UseCases from '../../components/UseCases.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import SourceEmbed from '../../components/SourceEmbed.astro';
import HireCta from '../../components/HireCta.astro';
import { CATEGORY_META } from '../../lib/categories';
import { extractSteps } from '../../lib/steps';
import { howToJsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const workflows = await getCollection('workflows', (e) => e.data.published);
  return workflows.map((w) => ({ params: { slug: w.id }, props: { workflow: w } }));
}

const { workflow } = Astro.props;
const d = workflow.data;
const { Content } = await render(workflow);

const pageUrl = new URL(`/workflows/${workflow.id}/`, Astro.site).toString();
const steps = extractSteps(workflow.body ?? '');
const jsonLd = howToJsonLd(d, steps, pageUrl);
const category = CATEGORY_META[d.category];
const isFree = d.tools.every((t) => t.pricing !== 'paid');
---

<Base title={d.title} description={d.description} ogImage={`/og/${workflow.id}.png`}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="progress-bar" aria-hidden="true"></div>

  <article data-pagefind-body data-category={d.category}>
    <!-- Title block -->
    <header class="relative overflow-hidden rounded-2xl border border-line bg-surface p-6 sm:p-8 shadow-[0_1px_2px_rgba(28,23,19,0.04)]">
      <div class="glow h-48 w-48" style="background: var(--cat); opacity: 0.16; top:-4rem; right:-4rem;" aria-hidden="true"></div>
      <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5 font-mono text-[10px] font-bold uppercase tracking-[0.15em] text-ink-400">
        <Badge badge={d.badge} />
        <span>{d.difficulty}</span>
        <span class="text-ink-300">/</span>
        <span>⏱ {d.timeMinutes} min</span>
        <span class="text-ink-300">/</span>
        <a href={`/categories/${d.category}/`} class="hover:underline" style="color: var(--cat)">
          {category.emoji} {category.label}
        </a>
        {isFree && <span class="rounded-full border border-volt-400/40 bg-volt-400/10 px-2 py-0.5 text-volt-500">Free tools</span>}
      </div>
      <h1 class="mt-4 font-display text-3xl font-medium leading-[1.05] tracking-[-0.02em] text-ink-900 sm:text-[2.6rem]">
        {d.title}
      </h1>
      <p class="mt-4 text-sm leading-relaxed text-ink-600">
        <span class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent">Job to be done: </span>
        {d.jobToBeDone}
      </p>
      <div class="mt-5">
        <ToolsList tools={d.tools} />
      </div>
    </header>

    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_330px] lg:items-start lg:gap-10">
      <div class="min-w-0 lg:max-w-[70ch]">
        {d.nigeriaNotes && <div class="mt-5"><NigeriaNotes notes={d.nigeriaNotes} /></div>}
        {(d.nigeriaUseCases ?? []).length > 0 && <div class="mt-5"><UseCases cases={d.nigeriaUseCases} /></div>}
        <div class="workflow-body mt-8">
          <Content />
        </div>
        <HireCta variant="inline" workflowTitle={d.title} timeMinutes={d.timeMinutes} />
      </div>

      <aside class="mt-10 space-y-5 lg:sticky lg:top-20 lg:mt-8">
        <SourceEmbed source={d.source} />
        <div class="rounded-2xl border border-line bg-surface p-5 shadow-[0_1px_2px_rgba(28,23,19,0.04)]">
          <p class="mb-3 font-display text-lg font-semibold text-ink-900">Someone needs this workflow.</p>
          <ShareButtons title={d.title} url={pageUrl} />
        </div>
        <HireCta variant="sidebar" workflowTitle={d.title} timeMinutes={d.timeMinutes} />
      </aside>
    </div>
  </article>
</Base>

<!-- Adds a copy button to every prompt code block (PRD must-have). -->
<script is:inline>
  document.querySelectorAll('.workflow-body pre').forEach(function (pre) {
    var wrap = document.createElement('div');
    wrap.className = 'pre-wrap';
    pre.parentNode.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', function () {
      var code = pre.querySelector('code');
      var text = code ? code.innerText : pre.innerText;
      navigator.clipboard.writeText(text).then(function () {
        btn.textContent = 'Copied ✓';
        setTimeout(function () {
          btn.textContent = 'Copy';
        }, 2000);
      });
    });
    wrap.appendChild(btn);
  });
</script>
