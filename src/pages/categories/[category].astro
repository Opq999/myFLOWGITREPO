---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkflowCard from '../../components/WorkflowCard.astro';
import { CATEGORY_META } from '../../lib/categories';
import { CATEGORIES, type Category } from '../../lib/workflow-schema';

export function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as Category;
const meta = CATEGORY_META[category];

const workflows = (
  await getCollection('workflows', (e) => e.data.published && e.data.category === category)
).sort((a, b) => b.data.ingestedAt.valueOf() - a.data.ingestedAt.valueOf());
---

<Base title={meta.label} description={meta.blurb}>
  <header
    class="relative overflow-hidden rounded-2xl border border-line bg-surface p-6 sm:p-8 shadow-[0_1px_2px_rgba(28,23,19,0.04)]"
    data-category={category}
  >
    <div class="glow h-48 w-48" style="background: var(--cat); opacity: 0.18; top:-4rem; right:-3rem;" aria-hidden="true"></div>
    <p class="text-5xl">{meta.emoji}</p>
    <h1 class="mt-3 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900 sm:text-5xl">{meta.label}</h1>
    <p class="mt-2 max-w-xl leading-relaxed text-ink-600">{meta.blurb}</p>
    <p class="mt-3 font-mono text-[10px] font-bold uppercase tracking-[0.2em]" style="color: var(--cat)">
      {workflows.length} workflows in this category
    </p>
  </header>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {workflows.map((w) => <WorkflowCard workflow={w} />)}
  </div>
  {
    workflows.length === 0 && (
      <p class="mt-8 text-ink-400">
        No workflows here yet — the pipeline publishes new ones daily.{' '}
        <a href="/workflows/" class="text-accent underline underline-offset-2">
          Browse all workflows
        </a>
      </p>
    )
  }
</Base>
