---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkflowCard from '../../components/WorkflowCard.astro';
import PersonaFilter from '../../components/PersonaFilter.astro';
import { CATEGORY_META } from '../../lib/categories';
import { CATEGORIES, type Category } from '../../lib/workflow-schema';

export function getStaticPaths() {
  return CATEGORIES.map((category) => ({ params: { category } }));
}

const category = Astro.params.category as Category;
const meta = CATEGORY_META[category];

const workflows = (
  await getCollection('workflows', (e) => e.data.published && e.data.category === category)
).sort((a, b) => b.data.ingestedAt.valueOf() - a.data.ingestedAt.valueOf());
---

<Base title={meta.label} description={meta.blurb}>
  <header
    class="relative overflow-hidden rounded-2xl border border-line bg-surface p-6 sm:p-8 shadow-[0_1px_2px_rgba(28,23,19,0.04)]"
    data-category={category}
  >
    <div class="glow h-48 w-48" style="background: var(--cat); opacity: 0.18; top:-4rem; right:-3rem;" aria-hidden="true"></div>
    <p class="text-5xl">{meta.emoji}</p>
    <h1 class="mt-3 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900 sm:text-5xl">{meta.label}</h1>
    <p class="mt-2 max-w-xl leading-relaxed text-ink-600">{meta.blurb}</p>
    <p class="mt-3 font-mono text-[10px] font-bold uppercase tracking-[0.2em]" style="color: var(--cat)">
      {workflows.length} workflows in this category
    </p>
  </header>

  {workflows.length > 0 && <PersonaFilter />}

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {workflows.map((w) => <WorkflowCard workflow={w} />)}
  </div>
  <p id="persona-no-results" hidden class="mt-10 text-ink-400">
    No workflows for this persona in {meta.label} yet, try another, or{' '}
    <a href="/workflows/" class="text-accent underline underline-offset-2">browse all workflows</a>.
  </p>
  {
    workflows.length === 0 && (
      <p class="mt-8 text-ink-400">
        No workflows here yet, the pipeline publishes new ones daily.{' '}
        <a href="/workflows/" class="text-accent underline underline-offset-2">
          Browse all workflows
        </a>
      </p>
    )
  }
</Base>

<!-- Persona-only client-side filter (this page has no other filters). -->
<script is:inline>
  (function () {
    var personaChips = Array.prototype.slice.call(document.querySelectorAll('.persona-chip'));
    if (!personaChips.length) return;
    var cards = Array.prototype.slice.call(document.querySelectorAll('.workflow-card'));
    var noResults = document.getElementById('persona-no-results');
    var activePersona = '';

    function setPersona(persona) {
      activePersona = persona;
      personaChips.forEach(function (c) {
        c.setAttribute('aria-pressed', c.dataset.persona === persona ? 'true' : 'false');
      });
    }

    function apply() {
      var visible = 0;
      cards.forEach(function (card) {
        var personas = (card.dataset.personas || '').split(' ');
        var show = !activePersona || personas.indexOf(activePersona) !== -1;
        card.hidden = !show;
        if (show) visible++;
      });
      if (noResults) noResults.hidden = visible > 0;

      var params = new URLSearchParams(location.search);
      if (activePersona) params.set('persona', activePersona);
      else params.delete('persona');
      var qs = params.toString();
      history.replaceState(null, '', qs ? '?' + qs : location.pathname);
    }

    personaChips.forEach(function (c) {
      c.addEventListener('click', function () {
        setPersona(c.dataset.persona);
        apply();
      });
    });

    var initial = new URLSearchParams(location.search).get('persona') || '';
    var hasChip = personaChips.some(function (c) {
      return c.dataset.persona === initial;
    });
    setPersona(hasChip ? initial : '');
    apply();
  })();
</script>
