---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import WorkflowCard from '../components/WorkflowCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { CATEGORY_META } from '../lib/categories';
import { CATEGORIES } from '../lib/workflow-schema';
import { SITE } from '../site.config';

const workflows = (await getCollection('workflows', (e) => e.data.published)).sort(
  (a, b) => b.data.ingestedAt.valueOf() - a.data.ingestedAt.valueOf()
);
const latest = workflows.slice(0, 6);

const fourteenDaysAgo = Date.now() - 14 * 24 * 60 * 60 * 1000;
const trending = workflows
  .filter((w) => w.data.ingestedAt.valueOf() >= fourteenDaysAgo)
  .sort((a, b) => b.data.score - a.data.score)
  .slice(0, 4);

const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c, workflows.filter((w) => w.data.category === c).length])
);
const freeCount = workflows.filter((w) => w.data.tools.every((t) => t.pricing !== 'paid')).length;
---

<Base title={SITE.name}>
  <!-- HERO -->
  <section class="relative overflow-hidden py-12 sm:py-16 lg:py-24">
    <div class="glow h-72 w-72 bg-volt-400/15 lg:h-96 lg:w-96" style="top:-6rem; left:-6rem;" aria-hidden="true"></div>
    <div class="glow h-72 w-72 bg-cat-coding/10 lg:h-96 lg:w-96" style="bottom:-8rem; right:-5rem;" aria-hidden="true"></div>

    <p class="font-mono text-[11px] font-bold uppercase tracking-[0.3em] text-volt-400">
      ⚡ A living library · refreshed daily by machine, proven by humans
    </p>
    <h1 class="mt-4 font-display text-[2.6rem] font-bold leading-[1.02] tracking-tight text-white sm:text-6xl lg:text-[5.5rem]">
      AI workflows<br />
      that actually<br />
      <span class="text-outline">get work done</span>
    </h1>
    <p class="mt-5 max-w-md text-base leading-relaxed text-zinc-400 lg:max-w-lg lg:text-lg">
      Not another tool list. Every entry is a reproducible recipe — the exact steps and
      copy-paste prompts a real person used, with the original source as proof.
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="/workflows/"
        class="rounded-xl bg-volt-400 px-6 py-3 font-display text-base font-bold text-ink-950 transition-transform hover:scale-[1.03] hover:bg-volt-300"
      >
        Browse the library →
      </a>
      <a
        href="/workflows/?free=1"
        class="rounded-xl border border-ink-700 bg-ink-900/70 px-6 py-3 font-display text-base font-bold text-zinc-200 transition-colors hover:border-volt-400 hover:text-volt-300"
      >
        Free tools only
      </a>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="grid grid-cols-3 divide-x divide-ink-800 rounded-2xl border border-ink-800 bg-ink-900/60">
    {
      [
        [String(workflows.length), 'workflows & growing daily'],
        [String(freeCount), 'run on 100% free tools'],
        ['₦0', 'to read. forever.'],
      ].map(([num, label]) => (
        <div class="px-4 py-5 text-center">
          <p class="font-display text-2xl font-bold text-volt-400 sm:text-3xl">{num}</p>
          <p class="mt-1 font-mono text-[9px] font-semibold uppercase tracking-[0.15em] text-zinc-500 sm:text-[10px]">
            {label}
          </p>
        </div>
      ))
    }
  </section>

  <!-- TRENDING -->
  {
    trending.length > 0 && (
      <section class="mt-12">
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="font-display text-2xl font-bold text-white">
            <span class="text-volt-400">/</span> Trending
          </h2>
          <p class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-600">
            top scores · last 14 days
          </p>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          {trending.map((w) => (
            <WorkflowCard workflow={w} />
          ))}
        </div>
      </section>
    )
  }

  <!-- LATEST -->
  <section class="mt-12">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="font-display text-2xl font-bold text-white">
        <span class="text-volt-400">/</span> Fresh from the pipeline
      </h2>
      <a href="/workflows/" class="font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-volt-400 hover:text-volt-300">
        all {workflows.length} →
      </a>
    </div>
    <div class="grid gap-3 md:grid-cols-2">
      {latest.map((w) => <WorkflowCard workflow={w} />)}
    </div>
  </section>

  <!-- BENTO CATEGORY GRID -->
  <section class="mt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-white">
      <span class="text-volt-400">/</span> Pick your job
    </h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:gap-4">
      {
        CATEGORIES.map((c, i) => (
          <a
            href={`/categories/${c}/`}
            class={`bento-tile rounded-2xl p-5 ${i === 0 ? 'col-span-2 sm:col-span-1' : ''}`}
            data-category={c}
          >
            <span class="text-3xl">{CATEGORY_META[c].emoji}</span>
            <p class="mt-3 font-display text-base font-bold leading-tight text-white">
              {CATEGORY_META[c].label}
            </p>
            <p class="mt-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--cat)">
              {counts[c]} workflows →
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="mt-14 rounded-2xl border border-ink-800 bg-ink-900/60 p-6">
    <h2 class="font-display text-xl font-bold text-white">
      <span class="text-volt-400">/</span> How this library stays honest
    </h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {
        [
          ['01', 'Found in the wild', 'A pipeline scans Reddit, Hacker News, Dev.to and more for workflows real people actually used.'],
          ['02', 'Scored ruthlessly', 'Every candidate faces a strict quality rubric. Hype, ads and tool lists get discarded.'],
          ['03', 'Proof attached', 'Every workflow links its original human source. No source, no entry.'],
        ].map(([n, title, body]) => (
          <div>
            <p class="font-mono text-[11px] font-bold text-volt-400">{n}</p>
            <p class="mt-1 font-display text-sm font-bold text-white">{title}</p>
            <p class="mt-1 text-[13px] leading-relaxed text-zinc-400">{body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <div class="mt-12">
    <NewsletterForm />
  </div>
</Base>
