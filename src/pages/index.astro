---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import WorkflowCard from '../components/WorkflowCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { CATEGORY_META } from '../lib/categories';
import { CATEGORIES } from '../lib/workflow-schema';
import { SITE } from '../site.config';

const workflows = (await getCollection('workflows', (e) => e.data.published)).sort(
  (a, b) => b.data.ingestedAt.valueOf() - a.data.ingestedAt.valueOf()
);
const latest = workflows.slice(0, 6);

const fourteenDaysAgo = Date.now() - 14 * 24 * 60 * 60 * 1000;
const trending = workflows
  .filter((w) => w.data.ingestedAt.valueOf() >= fourteenDaysAgo)
  .sort((a, b) => b.data.score - a.data.score)
  .slice(0, 4);

const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c, workflows.filter((w) => w.data.category === c).length])
);
const freeCount = workflows.filter((w) => w.data.tools.every((t) => t.pricing !== 'paid')).length;
---

<Base title={SITE.name}>
  <!-- HERO -->
  <section class="relative overflow-hidden py-12 sm:py-16 lg:py-24">
    <div class="glow h-72 w-72 bg-volt-400/20 lg:h-[26rem] lg:w-[26rem]" style="top:-7rem; left:-7rem;" aria-hidden="true"></div>
    <div class="glow h-72 w-72 bg-cat-coding/15 lg:h-96 lg:w-96" style="bottom:-9rem; right:-5rem;" aria-hidden="true"></div>

    <p class="inline-flex items-center gap-2 rounded-full border border-line-strong bg-surface px-3 py-1 font-mono text-[11px] font-bold uppercase tracking-[0.22em] text-accent">
      ⚡ A living library · refreshed daily by machine, proven by humans
    </p>
    <h1 class="mt-5 font-display text-[2.9rem] font-medium leading-[0.98] tracking-[-0.025em] text-ink-900 sm:text-6xl lg:text-[5.4rem]">
      AI workflows<br />
      that <em class="font-semibold italic text-accent">actually</em><br />
      <span class="text-outline">get work done</span>
    </h1>
    <p class="mt-6 max-w-md text-base leading-relaxed text-ink-600 lg:max-w-lg lg:text-lg">
      Not another tool list. Every entry is a reproducible recipe — the exact steps and
      copy-paste prompts a real person used, with the original source as proof.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/workflows/"
        class="rounded-full bg-ink-900 px-6 py-3 font-sans text-base font-semibold text-paper transition-transform hover:scale-[1.03]"
      >
        Browse the library →
      </a>
      <a
        href="/workflows/?free=1"
        class="rounded-full border border-line-strong bg-surface px-6 py-3 font-sans text-base font-semibold text-ink-800 transition-colors hover:border-accent hover:text-accent"
      >
        Free tools only
      </a>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="grid grid-cols-3 divide-x divide-line rounded-2xl border border-line bg-surface shadow-[0_1px_2px_rgba(28,23,19,0.04)]">
    {
      [
        [String(workflows.length), 'workflows & growing daily'],
        [String(freeCount), 'run on 100% free tools'],
        ['₦0', 'to read. forever.'],
      ].map(([num, label]) => (
        <div class="px-4 py-5 text-center">
          <p class="font-display text-3xl font-semibold text-ink-900 sm:text-4xl">{num}</p>
          <p class="mt-1 font-mono text-[9px] font-semibold uppercase tracking-[0.15em] text-ink-400 sm:text-[10px]">
            {label}
          </p>
        </div>
      ))
    }
  </section>

  <!-- TRENDING -->
  {
    trending.length > 0 && (
      <section class="mt-14">
        <div class="mb-5 flex items-end justify-between">
          <div>
            <p class="font-mono text-[10px] font-bold uppercase tracking-[0.22em] text-accent">Top scores · last 14 days</p>
            <h2 class="mt-1 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900">Trending now</h2>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {trending.map((w) => (
            <WorkflowCard workflow={w} />
          ))}
        </div>
      </section>
    )
  }

  <!-- LATEST -->
  <section class="mt-16">
    <div class="mb-5 flex items-end justify-between">
      <div>
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.22em] text-accent">Fresh from the pipeline</p>
        <h2 class="mt-1 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900">Latest workflows</h2>
      </div>
      <a href="/workflows/" class="shrink-0 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-accent hover:text-volt-500">
        all {workflows.length} →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((w) => <WorkflowCard workflow={w} />)}
    </div>
  </section>

  <!-- BENTO CATEGORY GRID -->
  <section class="mt-16">
    <p class="font-mono text-[10px] font-bold uppercase tracking-[0.22em] text-accent">Browse by goal</p>
    <h2 class="mt-1 mb-5 font-display text-3xl font-medium tracking-[-0.02em] text-ink-900">Pick your job</h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:gap-4">
      {
        CATEGORIES.map((c, i) => (
          <a
            href={`/categories/${c}/`}
            class={`bento-tile rounded-2xl p-5 ${i === 0 ? 'col-span-2 sm:col-span-1' : ''}`}
            data-category={c}
          >
            <span class="text-3xl">{CATEGORY_META[c].emoji}</span>
            <p class="mt-3 font-display text-lg font-semibold leading-tight text-ink-900">
              {CATEGORY_META[c].label}
            </p>
            <p class="mt-1 font-mono text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--cat)">
              {counts[c]} workflows →
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="mt-16 rounded-2xl border border-line bg-surface p-6 sm:p-8 shadow-[0_1px_2px_rgba(28,23,19,0.04)]">
    <h2 class="font-display text-2xl font-medium tracking-[-0.02em] text-ink-900">How this library stays honest</h2>
    <div class="mt-5 grid gap-5 sm:grid-cols-3">
      {
        [
          ['01', 'Found in the wild', 'A pipeline scans Reddit, Hacker News, Dev.to and more for workflows real people actually used.'],
          ['02', 'Scored ruthlessly', 'Every candidate faces a strict quality rubric. Hype, ads and tool lists get discarded.'],
          ['03', 'Proof attached', 'Every workflow links its original human source. No source, no entry.'],
        ].map(([n, title, body]) => (
          <div>
            <p class="font-display text-2xl font-semibold text-accent">{n}</p>
            <p class="mt-1 font-display text-base font-semibold text-ink-900">{title}</p>
            <p class="mt-1 text-[13px] leading-relaxed text-ink-500">{body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <div class="mt-12">
    <NewsletterForm />
  </div>
</Base>
