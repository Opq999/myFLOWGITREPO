{
  "name": "opqai",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "pipeline": "tsx --env-file-if-exists=.env pipeline/run.ts",
    "pipeline:dry": "tsx --env-file-if-exists=.env pipeline/run.ts --dry-run",
    "pipeline:backfill": "tsx --env-file-if-exists=.env pipeline/run.ts --backfill",
    "pipeline:usecases": "tsx --env-file-if-exists=.env pipeline/backfill-usecases.ts",
    "pipeline:rewrite": "tsx --env-file-if-exists=.env pipeline/rewrite-clarity.ts",
    "og": "tsx scripts/gen-og-cards.ts",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.0.0",
    "astro-og-canvas": "^0.11.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "fast-xml-parser": "^5.8.0",
    "pagefind": "^1.5.2",
    "playwright-core": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
