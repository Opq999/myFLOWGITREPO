# Required for scoring + drafting (free key: https://aistudio.google.com)
GEMINI_API_KEY=
# Optional extra free-tier keys (separate Google accounts/projects). Each adds
# its own daily + per-minute quota; the pipeline rotates across all of them, so
# more keys = more workflows per day at $0. Add as many as you like.
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# (or comma-separate them all in one var:)
# GEMINI_API_KEYS=key1,key2,key3

# Optional but recommended: official Reddit API access, never IP-blocked.
# Create a free "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: enables the YouTube source (free key: https://console.cloud.google.com, YouTube Data API v3)
YOUTUBE_API_KEY=

# Optional: raises GitHub search rate limits
GITHUB_TOKEN=

# Optional: override the Gemini model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
